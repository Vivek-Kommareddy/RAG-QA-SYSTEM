# Copy this file to .env and fill in the appropriate values.

OPENAI_API_KEY=
# Optional: API key for Anthropic models
ANTHROPIC_API_KEY=

# Choose the provider for the language model.  Valid options: openai, anthropic, ollama
LLM_PROVIDER=openai

# The name of the model to use for completions/questions
LLM_MODEL=gpt-3.5-turbo

# Embedding model.  Use `text-embedding-3-small` for OpenAI or `all-MiniLM-L6-v2` for sentence-transformers.
EMBEDDING_MODEL=text-embedding-3-small

# Directory for persisting ChromaDB data
CHROMA_PERSIST_DIR=chroma_data

# Chunking parameters
CHUNK_SIZE=512
CHUNK_OVERLAP=50

# Retrieval parameters
TOP_K=5
RERANK_ENABLED=false